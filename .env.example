# Local development defaults (no Docker). Copy to backend/.env
DATABASE_URL=sqlite+aiosqlite:///./dopewis.db
DATABASE_URL_SYNC=sqlite:///./dopewis.db

# Docker / production PostgreSQL (uncomment when using docker compose)
# DATABASE_URL=postgresql+asyncpg://dopewis:dopewis_secret@localhost:5432/dopewis
# DATABASE_URL_SYNC=postgresql://dopewis:dopewis_secret@localhost:5432/dopewis
POSTGRES_USER=dopewis
POSTGRES_PASSWORD=dopewis_secret_change_in_production
POSTGRES_DB=dopewis

SECRET_KEY=change-this-to-a-long-random-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

MLFLOW_TRACKING_URI=file:../mlruns
MLFLOW_EXPERIMENT_NAME=dopewis-outbreak-prediction

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_FROM_EMAIL=alerts@dopewis.health

NEXT_PUBLIC_MAPBOX_TOKEN=

RATE_LIMIT_PER_MINUTE=120
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

APP_NAME=DOPEWIS
ENVIRONMENT=development
